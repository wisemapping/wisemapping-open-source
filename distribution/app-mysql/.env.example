# WiseMapping Data Directory (Required)
# Absolute path where database files and logs will be stored
WISEMAPPING_DATA_DIR=/path/to/your/data

# MySQL Root Password (Required)
MYSQL_ROOT_PASSWORD=your_secure_password

# Database Configuration (Optional - Defaults shown)
# MYSQL_DATABASE=wisemapping
# MYSQL_USER=wisemapping
# MYSQL_PASSWORD=password
# MYSQL_PORT=3306

# WiseMapping Application Configuration (Optional - Defaults shown)
# WISEMAPPING_PORT=80
# JAVA_OPTS=-Xmx2048m -Xms1024m
